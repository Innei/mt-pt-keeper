{
  "name": "mt-pt-keeper",
  "version": "0.1.0",
  "description": "A Playwright-based session keepalive daemon for MT-PT / M-Team accounts with Telegram alerts.",
  "type": "module",
  "license": "MIT",
  "author": "Innei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Innei/mt-pt-keeper.git"
  },
  "bugs": {
    "url": "https://github.com/Innei/mt-pt-keeper/issues"
  },
  "homepage": "https://github.com/Innei/mt-pt-keeper#readme",
  "keywords": [
    "mt-pt",
    "m-team",
    "private-tracker",
    "playwright",
    "session-keepalive",
    "telegram",
    "cron",
    "typescript"
  ],
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "tsx watch src/index.ts daemon",
    "init-session": "tsx src/index.ts init-session",
    "once": "tsx src/index.ts once",
    "daemon": "tsx src/index.ts daemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js daemon",
    "start:init-session": "node dist/index.js init-session",
    "start:once": "node dist/index.js once",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@playwright/test": "^1.52.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
