# M-Team / MT-PT entry. Override if your account uses another mirror/domain.
MT_PT_BASE_URL=https://kp.m-team.cc/

# Optional comma-separated pages/endpoints to visit for session keepalive.
# Default is MT_PT_BASE_URL. Use authenticated pages that trigger token refresh.
KEEPER_KEEPALIVE_URLS=

# Daily schedule in cron format. Default: 09:00 Asia/Shanghai every day.
KEEPER_CRON=0 9 * * *
KEEPER_TIMEZONE=Asia/Shanghai

# Browser/runtime options.
KEEPER_HEADLESS=true
KEEPER_USER_DATA_DIR=.keeper/browser-profile
KEEPER_STATE_FILE=.keeper/state.json
KEEPER_SCREENSHOT_DIR=.keeper/screenshots
KEEPER_INTERACTION_ENABLED=true
KEEPER_DETAIL_LINK_SELECTOR=
KEEPER_MODAL_CLOSE_SELECTOR=
LOG_LEVEL=info

# Optional session detection tuning. Leave empty unless the site changes.
MT_PT_USERNAME_SELECTOR=
MT_PT_PASSWORD_SELECTOR=
MT_PT_SUCCESS_URL_PATTERN=
MT_PT_EXPIRED_URL_PATTERN=
MT_PT_SUCCESS_TEXT_PATTERN=
MT_PT_EXPIRED_TEXT_PATTERN=

# Notifications. Telegram always receives success/failure alerts when configured.
# KEEPER_NOTIFY_SUCCESS only controls success messages for the generic webhook.
KEEPER_NOTIFY_SUCCESS=false
KEEPER_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
